# --- Database ---
# Local Docker Postgres (see docker-compose.yml). Supabase-compatible schema.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/build_radar

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Crawlers ---
# Create a classic or fine-grained token at https://github.com/settings/tokens
# Public read access is enough for the GitHub crawler.
GITHUB_TOKEN=

# Background indexing (docker `crawler` service and/or API on startup / stale search).
BOOTSTRAP_MIN_ARTIFACTS=40
BOOTSTRAP_GITHUB_QUERY_LIMIT=7
# Set SKIP_BOOTSTRAP=1 on crawler container to disable first-run bootstrap only.

# Always-on crawler daemon handles freshness; search never crawls (fast + cool).
BACKGROUND_CRAWL_ON_SEARCH=false
BOOTSTRAP_CRAWL_ON_START=false
CRAWL_DAEMON_TICK_SECONDS=60
# Resource caps for the docker crawler service.
CRAWLER_CPUS=1.5
CRAWLER_MEM=2g
CRAWLER_THREADS=2
# Per-run breadth (rotates across the full topic set each cycle).
HN_WINDOW=8
ARXIV_WINDOW=4
GITHUB_WINDOW=6
HF_WINDOW=6
RSS_WINDOW=4
# Substance gates (raise to trim low-signal noise, lower for more volume).
CRAWL_RELEVANCE_MIN=0.22
CRAWL_MIN_TEXT_LEN=60

# --- Embeddings ---
# Local SentenceTransformers model. No paid LLM calls.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval tuning ---
# HNSW search effort (vector recall vs latency). pgvector default is 40.
HNSW_EF_SEARCH=200

# --- Stage-2 learned reranker (LightGBM LambdaMART) ---
# On by default. Trained + nested-CV validated by apps/api/scripts/train_ltr.py.
# No model download; falls back to the linear blend if unavailable.
LTR_ENABLED=true

# --- Diversity (Maximal Marginal Relevance) ---
# Off by default (UX variety, neutral on relevance). 1.0=pure relevance.
MMR_ENABLED=false
MMR_LAMBDA=0.7

# --- Pseudo-relevance feedback (vector Rocchio) ---
# Off by default: measured neutral on this corpus. Eval-gated.
PRF_ENABLED=false

# --- Reranking (stage-2 cross-encoder, retrieve-then-rerank) ---
# Off by default: the eval (apps/api/scripts/eval_search.py) shows the
# general-domain ms-marco reranker loses to stage-1 hybrid on this corpus.
# Flip to true only after a model beats stage-1 in the eval.
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=12
RERANK_WEIGHT=0.45

# --- Service base URLs ---
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
