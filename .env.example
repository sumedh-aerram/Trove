# --- Database ---
# Local Docker Postgres (see docker-compose.yml). Supabase-compatible schema.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/build_radar

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Crawlers ---
# Create a classic or fine-grained token at https://github.com/settings/tokens
# Public read access is enough for the GitHub crawler.
GITHUB_TOKEN=

# Background indexing (docker `crawler` service and/or API on startup / stale search).
BOOTSTRAP_MIN_ARTIFACTS=40
BOOTSTRAP_GITHUB_QUERY_LIMIT=7
# Set SKIP_BOOTSTRAP=1 on crawler container to disable first-run bootstrap only.

# Always-on crawler daemon handles freshness; search never crawls (fast + cool).
BACKGROUND_CRAWL_ON_SEARCH=false
BOOTSTRAP_CRAWL_ON_START=false
CRAWL_DAEMON_TICK_SECONDS=60
# Resource caps for the docker crawler service.
CRAWLER_CPUS=1.5
CRAWLER_MEM=2g
CRAWLER_THREADS=2
# Per-run breadth (rotates across the full topic set each cycle).
HN_WINDOW=8
ARXIV_WINDOW=4
GITHUB_WINDOW=6

# --- Embeddings ---
# Local SentenceTransformers model. No paid LLM calls.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Service base URLs ---
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
