# Trove — example cron entries (adjust paths and venv)
# Install: crontab -e
#
# Assumes:
#   REPO=/Users/you/Trove
#   VENV=$REPO/workers/.venv/bin/python
#   cd $REPO/workers before each job

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# GitHub — every 45 minutes
*/45 * * * * cd "/Users/you/Trove/workers" && /path/to/.venv/bin/python run_scheduled.py github >> /tmp/trove-github.log 2>&1

# Hacker News — every 20 minutes
*/20 * * * * cd "/Users/you/Trove/workers" && /path/to/.venv/bin/python run_scheduled.py hn >> /tmp/trove-hn.log 2>&1

# arXiv — every 8 hours
0 */8 * * * cd "/Users/you/Trove/workers" && /path/to/.venv/bin/python run_scheduled.py arxiv >> /tmp/trove-arxiv.log 2>&1

# RSS — every 45 minutes (when implemented)
# */45 * * * * cd "/Users/you/Trove/workers" && /path/to/.venv/bin/python run_scheduled.py rss >> /tmp/trove-rss.log 2>&1

# Backfill embeddings after crawls — every 2 hours
15 */2 * * * cd "/Users/you/Trove/workers" && /path/to/.venv/bin/python run_scheduled.py embeddings >> /tmp/trove-emb.log 2>&1

# Self-improving loop: harvest real usage, retrain the reranker, guard the
# frozen held-out eval, roll back on regression — daily at 04:00.
0 4 * * * cd "/Users/you/Trove/apps/api" && DATABASE_URL=postgresql://postgres:postgres@localhost:5433/build_radar PYTHONPATH=. /path/to/.venv/bin/python scripts/refresh_models.py >> /tmp/trove-refresh.log 2>&1
